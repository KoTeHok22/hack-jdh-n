# =============================================================================
# Hypothesis Factory - Конфигурация хакатон Норникель 2026
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your API keys
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 1. YANDEX AI STUDIO (REQUIRED)
# -----------------------------------------------------------------------------
# Бесплатный безлимит для хакатона. Получить ключ:
# https://aistudio.yandex.ru/docs/ru/ai-studio/quickstart/
#
# ВАЖНО: Ключ на всю команду, не на участника
# Траты отслеживаются, но не ограничены
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# -----------------------------------------------------------------------------
# 2. LLM CONFIGURATION
# -----------------------------------------------------------------------------
# Для хакатона используем Yandex AI Studio (бесплатно)
LLM_PROVIDER=yandex

# Если хотите использовать DeepSeek/OpenAI (платно):
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key_here
# LLM_API_BASE=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-pro

# -----------------------------------------------------------------------------
# 3. EMBEDDING API (REQUIRED)
# -----------------------------------------------------------------------------
# Cloud.ru API (рекомендуется для русского языка)
# Получить ключ: https://cloud.ru/
# Альтернатива: OpenAI embeddings (работает тоже)
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://foundation-models.api.cloud.ru/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIM=1024

# -----------------------------------------------------------------------------
# 4. OCR PROVIDERS (выберите один)
# -----------------------------------------------------------------------------
# Вариант 1: Mistral API (простой, платный ~$0.001/страница)
# Получить ключ: https://mistral.ai/
OCR_PROVIDER=mistral
MISTRAL_API_KEY=your_mistral_api_key_here

# Вариант 2: PaddleOCR (бесплатный, локальный, хорошее качество)
# OCR_PROVIDER=paddle
# (не требует ключа, автоматически загружается модель)

# Вариант 3: GLM-OCR (требует GPU 4-8GB VRAM)
# Запуск: docker compose --profile gpu up
# OCR_PROVIDER=glm
# HF_TOKEN=your_huggingface_token_here

# -----------------------------------------------------------------------------
# 5. DATABASE (не меняйте если используете docker-compose)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@postgres:5432/hypothesis_db

# -----------------------------------------------------------------------------
# 6. OPTIONAL SETTINGS
# -----------------------------------------------------------------------------
# Увеличьте если API медленный (по умолчанию 30 сек)
# API_TIMEOUT=60

# Увеличьте для больших документов (по умолчанию 32000 токенов)
# LLM_MAX_TOKENS=64000

# Debug mode (для разработки)
# DEBUG=true

# Логирование (debug/info/warning/error)
# LOG_LEVEL=info

# Количество параллельных LLM запросов (по умолчанию 5)
# PARALLEL_LLM_REQUESTS=5

# Максимум документов в batch (по умолчанию 100)
# MAX_BATCH_SIZE=100
